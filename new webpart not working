function getModifiedDateString(date)
{
    var dateUTC;

	if ( typeof date === "string" ) {

		// Convert UTC string to date object
		var d = new Date();
		var year = date.split('-')[0];
		var month = date.split('-')[1] - 1;
		var day;
		var hour;
		var minute;
		var second;
		day = date.split('-')[2].split('T')[0];
		hour = date.split('T')[1].split(':')[0];
		minute = date.split('T')[1].split(':')[1].split(':')[0];
		second = date.split('T')[1].split(':')[2].split('Z')[0];
		dateUTC = new Date( Date.UTC( year, month, day, hour, minute, second ) );
	}
	else if ( typeof date === "object" ) {
		dateUTC = date;
	}
	else {
		alert( "Date is not a valid string or date object." );
	}
	//dateUTC.addHours(-3);
	var rc = "";
	/*rc += (date.getMonth()+1).toString();
	rc += "/";
	rc += date.getDate().toString();
	rc += "/";
	rc += date.getFullYear().toString();
	rc += " at ";*/
	if(DST(dateUTC))
	{
	//dateUTC.addHours(-1);
	}
	if(dateUTC.getHours() > 11)
	{
		if(dateUTC.getHours() > 12)
	    rc += (dateUTC.getHours() - 12).toString();
	    else
	    rc += dateUTC.getHours().toString();
		rc += ":";
		if(dateUTC.getMinutes() > 10)
		{
		rc += dateUTC.getMinutes().toString();
		}
		else
		{
		rc += "00";
		}		
		rc += " PM";
	}
	else
	{
		rc += dateUTC.getHours().toString();
		rc += ":";
		if(dateUTC.getMinutes() > 10)
		{
		rc += dateUTC.getMinutes().toString();
		}
		else
		{
		rc += "00";
		}
		rc += " AM";
	}
	return rc;
}

Date.prototype.addHours= function(h){
    this.setHours(this.getHours()+h);
    return this;
}

function DST(dateUTC){
var yr = dateUTC.getFullYear();
var dst_start = new Date("March 14, "+yr+" 02:00:00"); // 2nd Sunday in March can't occur after the 14th 
var dst_end = new Date("November 07, "+yr+" 02:00:00"); // 1st Sunday in November can't occur after the 7th
var day = dst_start.getDay(); // day of week of 14th
dst_start.setDate(14-day); // Calculate 2nd Sunday in March of this year
day = dst_end.getDay(); // day of the week of 7th
dst_end.setDate(7-day); // Calculate first Sunday in November of this year
if (dateUTC >= dst_start && dateUTC < dst_end){ //does dateUTC fall inside of DST period?
return true; //if so then return true
}
return false; //if not then return false
}

